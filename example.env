# PostgreSQL Connection string 
PRISMA_DATABASE_URL=postgresql://user:password@localhost:5432/dbname?schema=public

NTRIP_USER=username
NTRIP_PASSWORD=password123
NTRIP_HOST=ntrip.data.gnss.ga.gov.au
NTRIP_PORT=2101
NTRIP_MOUNT=COMA00AUS0
NTRIP_SECURE=false

# NTRIP output mode
# serial: write RTCM corrections directly to GNSS receiver
# tcp: expose RTCM corrections as tcpsvr://host:port
NTRIP_OUTPUT_MODE=serial
NTRIP_OUTPUT_HOST=localhost
NTRIP_OUTPUT_PORT=2102

# GNSS serial settings
GNSS_DEVICE=/dev/ttyUSB0
GNSS_BAUDRATE=460800
GNSS_CORRECTION_DEVICE=/dev/ttyUSB0
GNSS_CORRECTION_BAUDRATE=460800
GNSS_READ_DEVICE=/dev/ttyUSB0
GNSS_READ_BAUDRATE=460800

# GNSS reader ingest + health
GNSS_INGEST_URL=http://localhost:3000/api/gnss/position
GNSS_POST_INTERVAL_MS=1000
GNSS_STATUS_FILE=/tmp/agnerd-gnss-status.json
GNSS_INTERNAL_TOKEN=replace_me_with_long_random_secret


# Node debugging option 
NODE_OPTIONS=--inspect